{
  "name": "@unhosted-ai/mcp-server",
  "version": "0.0.1",
  "description": "MCP server that exposes a running unhosted daemon's local-first capabilities (memory, web fetch, vram-pool status) as tools to MCP-aware clients like Claude Desktop.",
  "license": "AGPL-3.0-or-later",
  "author": "Ankur Sinha",
  "type": "module",
  "bin": {
    "unhosted-mcp-server": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unhosted-ai/unhosted-plugins.git",
    "directory": "mcp-server"
  },
  "homepage": "https://github.com/unhosted-ai/unhosted-plugins/tree/main/mcp-server#readme",
  "bugs": "https://github.com/unhosted-ai/unhosted-plugins/issues",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "unhosted",
    "claude-desktop",
    "cursor",
    "zed",
    "local-first",
    "llama-cpp"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "node --test test/*.test.mjs",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  }
}
